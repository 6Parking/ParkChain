generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  username  String
  createdAt DateTime @default(now())

  spots    ParkingSpot[] @relation("UserSpots")
  bookings Booking[]     @relation("UserBookings")
}

model ParkingSpot {
  id          Int               @id @default(autoincrement())
  ownerId     Int
  latitude    Float
  longitude   Float
  city        String
  address     String
  hourlyRate  Float
  description String?
  hasCharger  Boolean           @default(false)
  isActive    Boolean           @default(true)
  size        String            @default("medium")
  imageUrl    String?
  owner       User              @relation("UserSpots", fields: [ownerId], references: [id])
  bookings    Booking[]
  surgeLogs   SurgePricingLog[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  spotId     Int
  renterId   Int
  startTime  DateTime
  endTime    DateTime
  totalPrice Float
  status     String   @default("PENDING")

  // -- Blockchain --
  contractTxHash String? @unique
  depositStatus  String? //  LOCKED, REFUNDED, SLASHED

  spot             ParkingSpot       @relation(fields: [spotId], references: [id])
  renter           User              @relation("UserBookings", fields: [renterId], references: [id])
  blockchainEvents BlockchainEvent[]
}

model SurgePricingLog {
  id         Int      @id @default(autoincrement())
  spotId     Int
  multiplier Float
  reason     String?
  createdAt  DateTime @default(now())

  spot ParkingSpot @relation(fields: [spotId], references: [id])
}

model BlockchainEvent {
  id        Int      @id @default(autoincrement())
  bookingId Int
  eventType String //  "FUNDS_LOCKED", "FUNDS_SLASHED", "FUNDS_REFUNDED"
  txHash    String   @unique
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}
